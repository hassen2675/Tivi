<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape><solid android:color="#1E1E3A"/><corners android:radius="16dp"/>
            <stroke android:width="2dp" android:color="#8B5CF6"/></shape>
    </item>
    <item>
        <shape><solid android:color="#0D0D1F"/><corners android:radius="16dp"/>
            <stroke android:width="1dp" android:color="#2A1A40"/></shape>
    </item>
</selector>
